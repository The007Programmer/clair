# local.env.example — copy to local.env and edit for this machine.
# clair reads local.env (gitignored) via clair.localenv.load(); values here are
# expanded for $HOME / ${HOME} only (no shell command substitution).

# Where your code lives. Used by templated agents/commands as ${CODE_ROOT}.
CODE_ROOT=$HOME/Documents/Code

# Optional secrets vault root. Leave EMPTY to disable vault-only template blocks.
VAULT_ROOT=

# AWS profile name substituted into settings.local.json as ${AWS_PROFILE}.
# Leave EMPTY if you do not use AWS.
AWS_PROFILE=

# Optional private overlay repo (git URL). Leave EMPTY for base-only setup.
OVERLAY_REPO=

# Optional path to an already-cloned overlay working tree. Takes precedence
# over OVERLAY_REPO when set+existing. Leave EMPTY to clone OVERLAY_REPO instead.
OVERLAY_DIR=
