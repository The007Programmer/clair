#!/usr/bin/env bash
# claude-setup pre-commit hook (contract §16).
# Runs `clair status scan` (secrets, always; base-purity for base files) and blocks
# the commit (nonzero exit) if there are any findings.
set -euo pipefail

# Resolve the repo root from this hook's location: .githooks/pre-commit -> repo root.
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${HOOK_DIR}/.." && pwd)"

# Ensure `clair` is importable even when git invokes the hook from a subdir.
export PYTHONPATH="${REPO_ROOT}${PYTHONPATH:+:${PYTHONPATH}}"

cd "${REPO_ROOT}"

if ! python3 -m clair status scan; then
    echo "" >&2
    echo "pre-commit: clair status scan found secrets or base-purity violations." >&2
    echo "pre-commit: fix the findings above, move company/personal content to the overlay," >&2
    echo "pre-commit: or templatize machine-specific values. Commit blocked." >&2
    exit 1
fi
